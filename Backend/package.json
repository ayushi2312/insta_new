{
  "name": "Root Backend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "start:all": "concurrently \"npm run start:auth\" \"npm run start:user\" \"npm run start:post\" \"npm run start:media\"",
    "start:auth": "cd auth-service && node server.js",
    "start:user": "cd user-service && node server.js",
    "start:post": "cd post-service && node server.js",
    "start:media": "cd media-service && node server.js"
  },
  "devDependencies": {
    "concurrently": "^8.2.0"
  },
  "dependencies": {
    "dotenv": "^17.3.1",
    "mysql2": "^3.19.1"
  }
}
